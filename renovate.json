{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": ["main"],
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "ignoreUnstable": true,
  "automergeSchedule": ["* 2-9 * * *"],
  "timezone": "CET",
  "automerge": true,
  "prHourlyLimit": 20,
  "rebaseWhen": "behind-base-branch"
}
